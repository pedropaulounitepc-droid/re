# ==========================================
# Supabase
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ==========================================
# Banco de dados (Prisma) — connection string do Supabase
# ==========================================
DATABASE_URL="postgresql://postgres:SENHA@db.SEU_PROJETO.supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:SENHA@db.SEU_PROJETO.supabase.co:5432/postgres"

# ==========================================
# Google OAuth (configurado dentro do Supabase Auth, mas as chaves ficam aqui como referência)
# ==========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==========================================
# Stripe
# ==========================================
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# ==========================================
# Mercado Pago
# ==========================================
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=

# ==========================================
# Revalida IA — deixe em branco por enquanto, plugue quando tiver a chave
# ==========================================
ANTHROPIC_API_KEY=

# ==========================================
# App
# ==========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
